# قالب الأسرار — انسخه إلى .env المحلي (غير المتعقَّب) واملأ القيم.
#
# ملاحظة المضيف مقابل Docker:
#   - القيم أدناه (mssql / postgres) هي أسماء خدمات Docker، تُستخدم حين يعمل
#     الـ backend داخل حاوية على شبكة sqlserver-docker_default (النشر — الخطة 4).
#   - عند تشغيل alembic/pytest على المضيف مباشرةً (الخطة 0)، تجاوَز القيم هكذا:
#       POSTGRES_HOST=localhost  و  POSTGRES_PORT=5433   (المضيف 5433 → الحاوية 5432؛
#                                   5432 محجوز على المضيف بحاوية أخرى)
#       MSSQL_HOST=localhost                              (المنفذ 1433 منشور كما هو)

# قاعدة المحاسبة (قراءة فقط)
MSSQL_HOST=mssql
MSSQL_PORT=1433
MSSQL_DB=AlBaytAlSaeid
MSSQL_READONLY_USER=cashflow_ro
MSSQL_READONLY_PASSWORD=__SET_ME__

# قاعدة التطبيق
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=cashflow
POSTGRES_USER=cashflow
POSTGRES_PASSWORD=__SET_ME__

# التطبيق
APP_SECRET_KEY=__SET_ME__
APP_TZ=Asia/Baghdad
ETL_DAILY_AT=02:00
